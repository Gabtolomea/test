@* Views/Admin/Announcements.cshtml *@
@model List<Announcement>
@{ ViewData["Title"] = "Announcements"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold">📢 Manage Announcements</h4>
    <a href="/Admin" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

@* Add Announcement Form *@
<div class="card shadow-sm mb-4">
    <div class="card-header bg-info text-white fw-semibold">Post New Announcement</div>
    <div class="card-body">
        <form asp-action="AddAnnouncement" method="post">
            <div class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Title</label>
                    <input type="text" name="title" class="form-control" placeholder="Announcement title" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Type</label>
                    <select name="type" class="form-select">
                        <option value="General">General</option>
                        <option value="Urgent">Urgent</option>
                        <option value="Event">Event</option>
                        <option value="Reminder">Reminder</option>
                    </select>
                </div>
                <div class="col-md-12">
                    <label class="form-label">Content</label>
                    <textarea name="content" class="form-control" rows="2" 
                              placeholder="Write your announcement here..." required></textarea>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-info text-white">📤 Post Announcement</button>
                </div>
            </div>
        </form>
    </div>
</div>

@* Existing Announcements *@
@if (!Model.Any())
{
    <div class="alert alert-light">No announcements posted yet.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Content</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td><strong>@a.Title</strong></td>
                            <td>
                                @{
                                    string typeBadge = a.Type switch {
                                        "Urgent"   => "bg-danger",
                                        "Event"    => "bg-success",
                                        "Reminder" => "bg-warning text-dark",
                                        _          => "bg-secondary"
                                    };
                                }
                                <span class="badge @typeBadge">@a.Type</span>
                            </td>
                            <td><small>@a.Content</small></td>
                            <td><small>@a.CreatedAt.ToString("MMM d, yyyy")</small></td>
                            <td>
                                <form asp-action="DeleteAnnouncement" method="post"
                                      onsubmit="return confirm('Delete this announcement?')">
                                    <input type="hidden" name="id" value="@a.Id" />
                                    <button class="btn btn-danger btn-sm">🗑 Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
