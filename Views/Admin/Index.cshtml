@* Views/Admin/Index.cshtml — Admin dashboard *@
@{ ViewData["Title"] = "Admin Dashboard"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold">🛡️ Admin Dashboard</h3>
    <div>
        <a href="/Admin/Users" class="btn btn-outline-primary btn-sm me-2">👥 Manage Users</a>
        <a href="/Admin/Announcements" class="btn btn-outline-info btn-sm">📢 Announcements</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white fw-semibold">
        Student Clearance Overview
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Student No.</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Progress</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.Students != null)
                {
                    @foreach (var s in ViewBag.Students)
                    {
                        int pct = s.Total > 0 ? (int)((double)s.Cleared / s.Total * 100) : 0;
                        <tr>
                            <td>@s.StudentNumber</td>
                            <td>@s.FullName</td>
                            <td><span class="badge bg-secondary">@s.StudentStatus</span></td>
                            <td style="min-width:150px">
                                <div class="progress" style="height:16px">
                                    <div class="progress-bar bg-success" style="width:@(pct)%">
                                        @s.Cleared/@s.Total
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (s.IsFullyCleared)
                                {
                                    <span class="badge bg-success">✅ Cleared</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">⏳ Pending</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
