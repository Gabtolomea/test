<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Online Clearance System</title>
    <!-- Bootstrap 5 for quick, clean styling -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

@* Show the nav bar only when the user is logged in *@
@if (User.Identity?.IsAuthenticated == true)
{
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🎓 Online Clearance</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <span class="nav-link text-white-50">
                            Hello, @User.FindFirst("FullName")?.Value
                        </span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Logout">Logout</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
}

<div class="container mt-4">
    @* Show success/error messages (TempData survives one redirect) *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
