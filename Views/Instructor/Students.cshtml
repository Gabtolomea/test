@* Views/Instructor/Students.cshtml — Approve/Decline clearance *@
@model InstructorClearanceViewModel
@{ ViewData["Title"] = "Student Clearances"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">@Model.SubjectTitle</h4>
        <small class="text-muted">MIS Code: @Model.MisCode</small>
    </div>
    <a href="/Instructor" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

@if (!Model.Students.Any())
{
    <div class="alert alert-info">No students enrolled in this subject yet.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Student No.</th>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Signed At</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Students)
                    {
                        <tr>
                            <td>@s.StudentNumber</td>
                            <td>@s.InstructorName</td>  @* InstructorName reused for student name *@
                            <td>
                                @{
                                    string badge = s.Status == 2 ? "bg-success"
                                                 : s.Status == 3 ? "bg-danger"
                                                 : "bg-warning text-dark";
                                }
                                <span class="badge @badge">@s.StatusLabel</span>
                            </td>
                            <td>
                                <small>@(s.SignedAt?.ToString("MMM d, yyyy h:mm tt") ?? "—")</small>
                            </td>
                            <td>
                                @* Only show action buttons if not yet cleared *@
                                @if (s.Status != 2)
                                {
                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                        <input type="hidden" name="clearanceId" value="@s.Id" />
                                        <input type="hidden" name="status" value="2" />
                                        <button class="btn btn-success btn-sm">✔ Clear</button>
                                    </form>
                                    <button class="btn btn-danger btn-sm" 
                                            onclick="showDecline(@s.Id)">✖ Decline</button>
                                }
                                else
                                {
                                    <span class="text-success">✔ Done</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* Decline modal - asks for a reason *@
<div class="modal fade" id="declineModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateStatus" method="post">
                <input type="hidden" name="status" value="3" />
                <input type="hidden" name="clearanceId" id="declineClearanceId" />
                <div class="modal-header">
                    <h5 class="modal-title">Decline Clearance</h5>
                </div>
                <div class="modal-body">
                    <label class="form-label">Reason / Remarks</label>
                    <textarea name="remarks" class="form-control" rows="3" 
                              placeholder="Enter reason for declining..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Confirm Decline</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function showDecline(id) {
    document.getElementById('declineClearanceId').value = id;
    new bootstrap.Modal(document.getElementById('declineModal')).show();
}
</script>
