@* Views/Instructor/Index.cshtml — Instructor subject list *@
@{ ViewData["Title"] = "My Subjects"; }

<h3 class="fw-bold mb-4">👨‍🏫 My Subjects</h3>

@if (ViewBag.Message != null)
{
    <div class="alert alert-warning">@ViewBag.Message</div>
}

@if (ViewBag.Subjects != null)
{
    <div class="row">
        @foreach (var s in ViewBag.Subjects)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">@s.SubjectTitle</h5>
                        <p class="text-muted small">MIS Code: @s.MisCode</p>
                        <p>
                            <span class="badge bg-success">@s.ClearedCount Cleared</span>
                            <span class="badge bg-secondary">@s.StudentCount Total</span>
                        </p>
                    </div>
                    <div class="card-footer">
                        <a href="/Instructor/Students?misCode=@s.MisCode" class="btn btn-primary btn-sm">
                            View Students
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
